[Unit]
Description=Notify manaba assignments to Discord
Wants=network-online.target
After=network-online.target

[Service]
Type=oneshot
User=@USER@
Group=@USER@
WorkingDirectory=@INSTALL_DIR@
EnvironmentFile=@INSTALL_DIR@/.env
ExecStart=@INSTALL_DIR@/.venv/bin/python -m manaba_notifier.main

Nice=10
